# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key

# Database Configuration
DATABASE_URL=sqlite:///contentgenie.db
DEV_DATABASE_URL=sqlite:///contentgenie_dev.db

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key

# Firebase Configuration
FIREBASE_CREDENTIALS_PATH=path/to/firebase-credentials.json

# Redis Configuration (for caching and background tasks)
REDIS_URL=redis://localhost:6379/0

# Email Configuration (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Rate Limiting
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# Instagram Graph API Configuration
# Get these from: https://developers.facebook.com/apps/
# 
# IMPORTANT: Meta doesn't allow http://localhost as redirect URI
# Solution: Use ngrok for local development
# 
# Setup ngrok:
#   1. Install: https://ngrok.com/download
#   2. Run: ngrok http 5001
#   3. Copy the HTTPS URL (e.g., https://abc123.ngrok.io)
#   4. Set INSTAGRAM_REDIRECT_URI to: https://YOUR_NGROK_URL/api/instagram/callback
#   5. Add the same URL to Meta App Dashboard → Instagram → Valid OAuth Redirect URIs
#
# Required permissions in Meta App Dashboard:
#   - instagram_business_basic
#   - instagram_business_manage_comments
#   - instagram_business_manage_messages
#
INSTAGRAM_APP_ID=1229262612196429
