./deploy-to-aws.sh
#!/bin/bash

# AWS Deployment Script for ContentGenei
# This script automates the deployment of LinkoGenei and Analytics updates

set -e  # Exit on error

echo "🚀 ContentGenei AWS Deployment Script"
echo "======================================"
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration (UPDATE THESE)
AWS_HOST="ec2-user@your-ec2-ip"
AWS_KEY="path/to/your-key.pem"
BACKEND_PATH="/path/to/ContentGenei/backend"
FRONTEND_PATH="/path/to/ContentGenei/frontend"
PM2_APP_NAME="contentgenei-backend"

# Function to print colored output
print_status() {
    echo -e "${GREEN}✓${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

# Check if SSH key exists
if [ ! -f "$AWS_KEY" ]; then
    print_error "SSH key not found: $AWS_KEY"
    echo "Please update AWS_KEY in this script"
    exit 1
fi

echo "Step 1: Pulling latest code from GitHub..."
ssh -i "$AWS_KEY" "$AWS_HOST" << 'ENDSSH'
    cd $BACKEND_PATH
    echo "Pulling backend changes..."
    git pull origin main
    
    cd $FRONTEND_PATH
    echo "Pulling frontend changes..."
    git pull origin main
ENDSSH
print_status "Code pulled successfully"
echo ""

echo "Step 2: Installing dependencies..."
ssh -i "$AWS_KEY" "$AWS_HOST" << 'ENDSSH'
    cd $BACKEND_PATH
    source venv/bin/activate
    pip install -r requirements.txt --quiet
    
    cd $FRONTEND_PATH
    npm install --silent
ENDSSH
print_status "Dependencies installed"
echo ""

echo "Step 3: Building frontend..."
ssh -i "$AWS_KEY" "$AWS_HOST" << 'ENDSSH'
    cd $FRONTEND_PATH
    npm run build
ENDSSH
print_status "Frontend built successfully"
echo ""

echo "Step 4: Restarting backend service..."
ssh -i "$AWS_KEY" "$AWS_HOST" << ENDSSH
    pm2 restart $PM2_APP_NAME
    pm2 save
ENDSSH
print_status "Backend restarted"
echo ""

echo "Step 5: Verifying deployment..."
sleep 3

# Test health endpoint
HEALTH_CHECK=$(ssh -i "$AWS_KEY" "$AWS_HOST" "curl -s http://localhost:5001/api/health")
if echo "$HEALTH_CHECK" | grep -q "healthy"; then
    print_status "Backend health check passed"
else
    print_error "Backend health check failed"
    echo "Response: $HEALTH_CHECK"
fi
echo ""

echo "======================================"
echo -e "${GREEN}✓ Deployment Complete!${NC}"
echo ""
echo "Next steps:"
echo "1. Check logs: ssh -i $AWS_KEY $AWS_HOST 'pm2 logs $PM2_APP_NAME'"
echo "2. Test LinkoGenei: Visit your-domain/linkogenei"
echo "3. Test Analytics: Visit your-domain/analytics"
echo ""
echo "For detailed testing, see AWS_DEPLOYMENT_GUIDE.md"
Y

